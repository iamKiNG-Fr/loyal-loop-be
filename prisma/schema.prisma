generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WaitlistEntry {
  id           Int      @id @default(autoincrement())
  name         String
  businessName String
  email        String   @unique
  refCode      String   @unique
  refBy        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("waitlist")
}
